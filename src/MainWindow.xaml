<Window x:Class="Kinect_20_12_2023_V2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kinect_20_12_2023_V2"
        mc:Ignorable="d"
        Title="Gakivax - Bewegungsanalyse Software mit Kinect" Height="575" Width="500" Closed="MainWindowClosed">
    <Grid>
        <Button x:Name="btnFrei" Content="Frei" HorizontalAlignment="Center" Height="45" Margin="0,213,0,0" VerticalAlignment="Top" Width="324" Click="btnFrei_Click"/>
        <Button x:Name="btnSAS" Content="Stand up and sit down (SAS)" HorizontalAlignment="Center" Height="45" Margin="0,288,0,0" VerticalAlignment="Top" Width="324" Click="btnSAS_Click"/>
        <Button x:Name="btnPOCO" Content="Stance with closed feet and open and closed eyes (POCO)" HorizontalAlignment="Center" Height="45" Margin="0,363,0,0" VerticalAlignment="Top" Width="324" Click="btnPOCO_Click"/>
        <Button x:Name="btnSIP" Content="Stepping in Place (SIP)" HorizontalAlignment="Center" Height="45" Margin="0,438,0,0" VerticalAlignment="Top" Width="324" Click="btnSIP_Click"/>
        <Image HorizontalAlignment="Left" Height="182" Margin="75,34,0,0" VerticalAlignment="Top" Width="364" Source="/Gakivax_Logo.png"/>
        <TextBlock HorizontalAlignment="Left" Margin="450,500,0,0" TextWrapping="Wrap" Text="DV" VerticalAlignment="Top"/>
    </Grid>
</Window>
