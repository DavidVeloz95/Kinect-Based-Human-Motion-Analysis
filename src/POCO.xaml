        <TextBlock HorizontalAlignment="Center" Margin="0,24,0,0" TextWrapping="Wrap" Text="Stance with closed feet and open and closed eyes" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="20,361,0,0" TextWrapping="Wrap" Text="Anweisungen:" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,384,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="1 - Schließen Sie Ihre Füße. Wenn das Tonsignal ertönt, beginnt die Erfassung." Width="358"/>
        <TextBlock HorizontalAlignment="Left" Margin="20,416,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="2 - Nach dem Tonsignal schließen"/><Run Language="de-de" Text=" Sie die "/><Run Text="Augen"/><Run Language="de-de" Text="."/></TextBlock>
