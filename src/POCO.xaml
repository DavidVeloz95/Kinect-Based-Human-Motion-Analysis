        <TextBox x:Name="Name" HorizontalAlignment="Left" Height="23" Margin="87,497,0,0" TextWrapping="Wrap" Text="20122023Proband" VerticalAlignment="Top" Width="249"/>
        <TextBlock HorizontalAlignment="Left" Margin="20,501,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="Proband"/><Run Language="de-de" Text=" "/><Run Text="ID:"/></TextBlock>
        <TextBlock HorizontalAlignment="Center" Margin="0,437,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="35" Width="358"><Run Language="de-de" Text="3 - Wenn Sie ein anderes Audiosignal hören, machen Sie eine Pause."/></TextBlock>
        <TextBlock HorizontalAlignment="Center" Margin="0,472,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="35" Width="358"><Run Language="de-de" Text="4 - Wiederholen Sie den Test noch 2 Mal."/></TextBlock>
    </Grid>
</Window>
